@page "/admin/package_types"
@inject IRepository<PackageType> repository;
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Customer,Admin,BusinessOwner")]
<PageTitle>Package Types</PageTitle>

<h1>Package Types</h1>

@if (packageTypes == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-4">
        @foreach (var package in packageTypes)
        {
            <div class="col">
                <Card Class="h-100" TextAlignment="Alignment.Center">
                    <CardBody Class="d-flex flex-column h-100">
                        <CardTitle>@package.Name</CardTitle>
						<div class="mt-auto row row-cols-2 vertical-align-end">
							<Button Class="vertical-align-end col mt-auto align-self-end" Color="ButtonColor.Primary"
									@onclick="@(() => OpenEditModal(package))">Edit</Button>
							<Button Class="vertical-align-end col mt-auto align-self-end" Color="ButtonColor.Danger"
									@onclick="@(() => OpenDeleteModal(package))">Delete</Button>
						</div>
                    </CardBody>
                </Card>
            </div>
        }
    </div>
}

<Button Color="ButtonColor.Primary" Class="mb-3 padding: 5px 5px 5px 5px" @onclick="OpenAddModal">Add Package Type</Button>

<Modal @ref="deleteModal" Title="Delete" IsVerticallyCentered = "true">
	<BodyTemplate>
		<h1>Are you sure?</h1>
        <Button Type="ButtonType.Button" Color="ButtonColor.Secondary" @onclick="CloseDeleteModal">Cancel</Button>
		<Button Type="ButtonType.Button" Color="ButtonColor.Danger" @onclick="@(() => DeletePackage(editUid))">Delete</Button>
	</BodyTemplate>

</Modal>
<Modal @ref="modal" Title="@(isEdit ? "Edit Package Type" : "Add Package Type")" IsVerticallyCentered="true">
    <BodyTemplate>
        <EditForm EditContext="@editContext" OnValidSubmit="HandleOnValidSubmit">
            <DataAnnotationsValidator />

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Name <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <TextInput @bind-Value="package.Name" Placeholder="Enter name" />
                    <ValidationMessage For="@(() => package.Name)" />
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <Button Type="ButtonType.Button" Color="ButtonColor.Secondary" @onclick="CloseModal">Cancel</Button>
                <Button Type="ButtonType.Submit" Color="ButtonColor.Success">Save</Button>
            </div>
        </EditForm>
    </BodyTemplate>
</Modal>

@code {
    private List<PackageType>? packageTypes;
    private Modal modal = default!;
    private Modal deleteModal = default!;
    private PackageTypeView package = new();
    private EditContext? editContext;
    private Guid? editUid;
    private bool isEdit => editUid is not null;

    protected override async Task OnInitializedAsync()
    {
        await LoadPackageTypes();
    }

	private async Task DeletePackage(Guid? editUid) {
        if (editUid is null )
        {
            await deleteModal.HideAsync();
            await LoadPackageTypes();
            return;
        }
        await repository.DeleteAsync((Guid)editUid);

        await deleteModal.HideAsync();
        await LoadPackageTypes();
	}
    private async Task LoadPackageTypes()
    {
        packageTypes = await repository.GetAllAsync();
    }

    private async Task OpenAddModal()
    {
        editUid = null;
        package = new();
        editContext = new(package);
        await modal.ShowAsync();
    }

    private async Task OpenDeleteModal(PackageType b)
    {
        editUid = b.Uid;
        await deleteModal.ShowAsync();
    }

    private async Task OpenEditModal(PackageType b)
    {
        editUid = b.Uid;
        package = new PackageTypeView
        {
            Name = b.Name,
        };
        editContext = new(package);
        await modal.ShowAsync();
    }

    private async Task CloseModal()
    {
        await modal.HideAsync();
    }

	private async Task CloseDeleteModal() {
		await deleteModal.HideAsync();
	}

    private async Task HandleOnValidSubmit()
    {
        var dto = new PackageType
        {
            Name = package.Name!,
        };

        if (editUid is not null)
        {
            dto.Uid = editUid.Value;
            await repository.UpdateAsync(dto, dto.Uid);
        }
        else
        {
            await repository.AddAsync(dto);
        }

        await modal.HideAsync();
        await LoadPackageTypes();
    }

    public class PackageTypeView
    {
        [Required(ErrorMessage = "Name required.")]
        [StringLength(100, ErrorMessage = "Name must not exceed 100 characters")]
        public string? Name { get; set; } = string.Empty;

    }
}