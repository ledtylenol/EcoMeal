@page "/businesses/{Uid:guid}"
@inject IRepository<Package> repository
@inject IRepository<PackageType> typeRepository
@inject IRepository<Business> businessRepository
@inject IRepository<Order> orderRepository
@inject IHttpContextAccessor context
@inject UserManager<User> manager;
@inject NavigationManager navManager;
@inject HttpClient http;
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using FuzzySharp;
@attribute [Authorize(Roles = "Customer,Admin,BusinessOwner")]
<PageTitle>Packages</PageTitle>

@if(business is not null)
{
<h1>Packages for @business.Name</h1>
}
else 
{
<h1>"Packages"</h1>
}
@if(packages is not null)
{
    @if (packages.Any())
    {
        <div class="row g-2 mb-3">
            <div class="col-md-6">
                <TextInput @bind-Value="searchTerm" @oninput="OnSearchChanged" Placeholder="Search name or description" />
            </div>
            <div class="col-md-6">
                <select class="form-select" @bind="selectedPackageTypeId">
                    <option value="">All package types</option>
                    @if (packageTypes != null)
                    {
                        @foreach (var t in packageTypes)
                        {
                            <option value="@t.Uid">@t.Name</option>
                        }
                    }
                </select>
            </div>
        </div>
    }  
    else 
    {
    <span>Nothing to see here...</span>
    }
}

@if(IsOwner)
{
    <Button Color="ButtonColor.Primary" Class="mb-3" @onclick="OpenAddModal">Add Package</Button>
}

@if (packages == null)
{
    <p><em>Loading...</em></p>
}
else
{

@if(currentOrderPackages.Any()) {
    <Accordion Class = "justify-content: top; align-items: right; col; mb-2" AlwaysOpen=true >
    @foreach(var op in currentOrderPackages) {
        <AccordionItem Title="@op.Package!.Name">
            <Content>
                <Card >
                    <CardBody Class="d-flex row width:50px">
                        <div class="mb-2" style="height: 150px; width: 100%; overflow: hidden; display: flex; align-items: center; justify-content: center; background-color: #e9ecef;">
                            @if (!string.IsNullOrEmpty(op.Package.ImageUrl))
                            {
                                <Image Src="@op.Package.ImageUrl" IsThumbnail="true" Style="height: 100%; width: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <Placeholder Style="height: 100%; width: 100%; display: block;" />
                            }
                        </div>
                        <CardText Class="mb-2">@op.Package.Description</CardText>
                        <CardText Class="mb-2"><strong>$@op.Package.Price.ToString("0.00")</strong> &middot; Qty: @op.Quantity</CardText>
                        <CardText Class="text-muted mb-2" style="font-size: 0.85rem;">
                            Pickup: @op.Package.PickupStart.ToString("MMM d, h:mm tt") - @op.Package.PickupEnd.ToString("MMM d, h:mm tt")
                        </CardText>
                    </CardBody>
                </Card>
            </Content>
        </AccordionItem>
    }
    <Button Class="my-2" @onclick="SubmitOrder" Color="ButtonColor.Success">Confirm</Button>
    </Accordion>

}
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-4">
        @foreach (var package in GetFilteredPackages())
        {
            <div class="col">
                <Card Class="h-100" @onclick="() => OpenBuyModal(package)">
                    <CardBody Class="d-flex flex-column h-100">
                        <div style="height: 100px; width: 100%; overflow: hidden; display: flex; align-items: center; justify-content: center; background-color: #e9ecef;">
                            @if (!string.IsNullOrEmpty(package.ImageUrl))
                            {
                                <Image Src="@package.ImageUrl" IsThumbnail="true" Style="height: 100%; width: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <Placeholder Style="height: 100%; width: 100%; display: block;" />
                            }
                        </div>
                        <CardTitle>@package.Name</CardTitle>
                        <CardText>@package.Description</CardText>
                        <CardText><strong>$@package.Price.ToString("0.00")</strong> &middot; Qty: @package.Quantity</CardText>
                        <CardText class="text-muted" style="font-size: 0.85rem;">
                            Pickup: @package.PickupStart.ToString("MMM d, h:mm tt") - @package.PickupEnd.ToString("MMM d, h:mm tt")
                        </CardText>
                        @if(IsOwner) {
						<div @onclick:stopPropagation="true" class="mt-auto row row-cols-2 vertical-align-end align-end">
							<Button Class="vertical-align-end col mt-auto align-self-end" Color="ButtonColor.Primary"
									@onclick="@(() => OpenEditModal(package))">
                                    Edit</Button>
							<Button Class="vertical-align-end col mt-auto align-self-end" Color="ButtonColor.Danger"
									@onclick="@(() => OpenDeleteModal(package))">
                                    Delete</Button>
						</div>
                        }
                    </CardBody>
                </Card>
            </div>
        }
    </div>
}

<Modal @ref="deleteModal" Title="Delete" IsVerticallyCentered = "true">
	<BodyTemplate>
		<h1>Are you sure?</h1>
        <Button Type="ButtonType.Button" Color="ButtonColor.Secondary" @onclick="CloseDeleteModal">Cancel</Button>
		<Button Type="ButtonType.Button" Color="ButtonColor.Danger" @onclick="@(() => DeletePackage(editUid))">Delete</Button>
	</BodyTemplate>

</Modal>

<Modal @ref="buyModal" Title="Buy Package" IsVerticallyCentered="true" Size="ModalSize.Large">
    <BodyTemplate>
            <div class="col">
                <Card Class="h-100">
                    <CardBody Class="d-flex flex-column h-100">
                        <div style="height: 100px; width: 100%; overflow: hidden; display: flex; align-items: center; justify-content: center; background-color: #e9ecef;">
                            @if (!string.IsNullOrEmpty(currentPackage!.ImageUrl))
                            {
                                <Image Src="@currentPackage!.ImageUrl" IsThumbnail="true" Style="height: 100%; width: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <Placeholder Style="height: 100%; width: 100%; display: block;" />
                            }
                        </div>
                        <CardTitle>@currentPackage!.Name</CardTitle>
                        <CardText>@currentPackage!.Description</CardText>
                        <CardText><strong>$@currentPackage.Price.ToString("0.00")</strong> &middot; Qty: @currentPackage.Quantity</CardText>
                        <CardText class="text-muted" style="font-size: 0.85rem;">
                            Pickup: @currentPackage.PickupStart.ToString("MMM d, h:mm tt") - @currentPackage.PickupEnd.ToString("MMM d, h:mm tt")
                        </CardText>
                    </CardBody>
                </Card>
            </div>

            <div class="col">
            <EditForm EditContext="@orderPackageEditContext" OnValidSubmit="HandleOnValidOrderPackageSubmit">
                <DataAnnotationsValidator />


                <div class="form-group row mb-3">
                    <label class="col-md-3 col-form-label">Quantity <span class="text-danger">*</span></label>
                    <div class="col-md-9">
                        <input type="number" min="1" max="@currentPackage!.Quantity" class="form-control" @bind="currentOrderPackage!.Quantity" />
                        <ValidationMessage For="@(() => currentOrderPackage!.Quantity)" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    @if(alreadyHadAdded)
                    {
                    <Button Type="ButtonType.Button" Color="ButtonColor.Danger" @onclick="@(() => DeleteOrderPackage(currentOrderPackage))" >Delete</Button>
                    }
                    <Button Type="ButtonType.Button" Color="ButtonColor.Secondary" @onclick="CloseBuyModal">Cancel</Button>
                    <Button Type="ButtonType.Submit" Color="ButtonColor.Success">Save</Button>
                </div>
            </EditForm>
            </div>
    </BodyTemplate>
</Modal>

<Modal @ref="modal" Title="@(isEdit ? "Edit Package" : "Add Package")" IsVerticallyCentered="true" Size="ModalSize.Large">
    <BodyTemplate>
        <EditForm EditContext="@editContext" OnValidSubmit="HandleOnValidSubmit">
            <DataAnnotationsValidator />

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Package Type <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <select class="form-select" @bind="package.PackageTypeId">
                        <option value="">Select a type</option>
                        @if (packageTypes != null)
                        {
                            @foreach (var t in packageTypes)
                            {
                                <option value="@t.Uid">@t.Name</option>
                            }
                        }
                    </select>
                    <ValidationMessage For="@(() => package.PackageTypeId)" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Name <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <TextInput @bind-Value="package.Name" Placeholder="Enter name" />
                    <ValidationMessage For="@(() => package.Name)" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Description</label>
                <div class="col-md-9">
                    <TextInput @bind-Value="package.Description" Placeholder="Enter description" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Price <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <input type="number" step="0.01" min="0.1" class="form-control" @bind="package.Price" />
                    <ValidationMessage For="@(() => package.Price)" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Quantity <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <input type="number" min="1" class="form-control" @bind="package.Quantity" />
                    <ValidationMessage For="@(() => package.Quantity)" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Pickup Start <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <input type="datetime-local" class="form-control" @bind="package.PickupStart" />
                    <ValidationMessage For="@(() => package.PickupStart)" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Pickup End <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <input type="datetime-local" class="form-control" @bind="package.PickupEnd" />
                    <ValidationMessage For="@(() => package.PickupEnd)" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Image</label>
                <div class="col-md-9">
                    <InputFile OnChange="HandleFileSelected" accept=".jpg,.jpeg,.png,.gif,.webp" />
                    @if (!string.IsNullOrEmpty(package.ImageUrl))
                    {
                        <div class="mt-2">
                            <img src="@package.ImageUrl" style="height: 80px;" />
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <Button Type="ButtonType.Button" Color="ButtonColor.Secondary" @onclick="CloseModal">Cancel</Button>
                <Button Type="ButtonType.Submit" Color="ButtonColor.Success">Save</Button>
            </div>
        </EditForm>
    </BodyTemplate>
</Modal>

@code {
    private static Guid CreatedUid = new("a48a3a93-9900-4bcc-b55a-f61bae0bdd3c");
    [Parameter]
    public Guid Uid {get; set;}
    private bool IsOwner {get; set;} = false;
    private List<Package>? packages;
    private Business? business;
    private User? currentUser;
    private Order? currentOrder;
    private OrderPackage? currentOrderPackage;

    private Package? currentPackage;
    private List<OrderPackage> currentOrderPackages = [];
    private List<PackageType>? packageTypes;
    private bool alreadyHadAdded = false;
    private uint purchaseQuantity = 0;

    private Modal modal = default!;
    private Modal buyModal = default!;

    private Modal deleteModal = default!;
    private PackageView package = new();
    private EditContext? editContext;
    private EditContext? orderPackageEditContext;
    private Guid? editUid;
    private bool isEdit => editUid is not null;

    private string searchTerm = string.Empty;
    private PackageType? selectedPackageType = null;
    private Guid? selectedPackageTypeId= default;

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
    }

    private List<Package> GetFilteredPackages()
    {
        if (packages is null) return new();

        var query = packages.AsEnumerable();

        if (selectedPackageTypeId is not null)
        {
            query = query.Where(b => b.PackageTypeId == selectedPackageTypeId);
        }

        query = query.Where(p => p.Quantity > 0);

        var term = searchTerm.Trim();
        if (string.IsNullOrEmpty(term)) return query.ToList();
        var max = (Package p) => Math.Max(Fuzz.PartialRatio(searchTerm, p.Name), Fuzz.PartialRatio(searchTerm, p.Description));
        var q = query.Select(b => new {Package=b, FuzzMax=max(b)});
        var fuzzList= q.ToList();
        fuzzList.Sort((l1, l2)=> l2.FuzzMax.CompareTo(l1.FuzzMax));
        query = fuzzList.Where(f => f.FuzzMax > 30).Select(l => l.Package);
            


        var list = query.ToList();
        return list;
    }

    private async Task DeleteOrderPackage(OrderPackage? currentOrderPackage) 
    {
        currentOrderPackages.Remove(currentOrderPackage!);
        await buyModal.HideAsync();

    }
    protected override async Task OnInitializedAsync()
    {
        await LoadPackages();
        packageTypes = await typeRepository.GetAllAsync();
        business = await businessRepository.GetByIdAsync(Uid);
        currentUser = await manager.GetUserAsync(context.HttpContext!.User);
        IsOwner = currentUser is not null && ((await manager.GetRolesAsync(currentUser)).Contains("Admin") || currentUser == business?.Owner!);
    }

    private async Task LoadPackages()
    {
        //TODO new interface?
        packages = await http.GetFromJsonAsync<List<Package>>($"api/package/business/{Uid}");
    }

    private async Task OpenAddModal()
    {
        editUid = null;
        package = new()
        {
            BusinessId = Uid,
            PickupStart = DateTime.Now,
            PickupEnd = DateTime.Now.AddHours(1)
        };
        editContext = new(package);
        await modal.ShowAsync();
    }
    private async Task OpenBuyModal(Package package)
    {
        
        if (currentOrder is null)
        {
            currentOrder = new();
            currentOrder.StatusId = CreatedUid;
            currentOrder.User = currentUser;
            currentOrder.Business = business;
        }
        //TODO: dict instead of list

        currentOrderPackage = currentOrderPackages.Find(op => op.PackageId == package.Uid);
        alreadyHadAdded = currentOrderPackage is not null;
        if (!alreadyHadAdded)
        {
            currentOrderPackage = new();
        }
        currentOrderPackage!.PackageId = package.Uid;
        currentOrderPackage.Package = package;
        currentPackage = package;
        orderPackageEditContext = new(currentOrderPackage);
        await buyModal.ShowAsync();
    }

	private async Task DeletePackage(Guid? editUid) 
    {

        if (editUid is null )
        {
            await deleteModal.HideAsync();
            await LoadPackages();
            return;
        }
		await repository.DeleteAsync((Guid)editUid);

        await deleteModal.HideAsync();
        await LoadPackages();
	}

    private async Task OpenDeleteModal(Package b)
    {
        editUid = b.Uid;
        await deleteModal.ShowAsync();
    }
    private async Task OpenEditModal(Package p)
    {
        editUid = p.Uid;
        package = new PackageView
        {
            BusinessId = Uid,
            PackageTypeId = p.PackageTypeId,
            Name = p.Name,
            Description = p.Description,
            Price = p.Price,
            Quantity = p.Quantity,
            PickupStart = p.PickupStart,
            PickupEnd = p.PickupEnd,
            ImageUrl = p.ImageUrl
        };
        editContext = new(package);
        await modal.ShowAsync();
    }

    private async Task CloseModal()
    {
        await modal.HideAsync();
    }

    private async Task CloseBuyModal() 
    {
        currentOrderPackage = null;
        await buyModal.HideAsync();
    }
    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        var content = new MultipartFormDataContent();
        var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        content.Add(new StreamContent(stream), "file", file.Name);

        var response = await http.PostAsync("api/package/upload_image", content);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<UploadResult>();
            package.ImageUrl = result!.Url;
        }
    }

	private async Task CloseDeleteModal() {
		await deleteModal.HideAsync();
	}


    private async Task HandleOnValidSubmit()
    {
        var dto = new Package
        {
            BusinessId = Uid,
            PackageTypeId = package.PackageTypeId!.Value,
            Name = package.Name,
            Description = package.Description,
            Price = package.Price,
            Quantity = package.Quantity,
            PickupStart = package.PickupStart,
            PickupEnd = package.PickupEnd,
            ImageUrl = package.ImageUrl
        };

        if (editUid is not null)
        {
            dto.Uid = editUid.Value;
            await repository.UpdateAsync(dto, dto.Uid);
        }
        else
        {
            await repository.AddAsync(dto);
        }

        await modal.HideAsync();
        await LoadPackages();
    }

    private async Task HandleOnValidOrderPackageSubmit()
    {
        if (!alreadyHadAdded)
        currentOrderPackages.Add(currentOrderPackage!);
        await buyModal.HideAsync();
        await LoadPackages();
    }

    private async Task SubmitOrder() 
    {
        currentOrder!.OrderPackages = currentOrderPackages;
        await orderRepository.AddAsync(currentOrder);
        navManager.NavigateTo($"/businesses/{Uid}", true);
        await LoadPackages();
    }
    public class PackageView
    {
        [Required(ErrorMessage = "Business required.")]
        public Guid? BusinessId { get; set; }

        [Required(ErrorMessage = "Package type required.")]
        public Guid? PackageTypeId { get; set; }

        [Required(ErrorMessage = "Name required.")]
        [StringLength(100, ErrorMessage = "Name must not exceed 100 characters")]
        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; } = string.Empty;

        [Range(0.1, float.MaxValue, ErrorMessage = "Price must be positive")]
        public float Price { get; set; }

        [Range(1, double.MaxValue, ErrorMessage = "Quantity must be above 0")]
        public uint Quantity { get; set; }

        [Required(ErrorMessage = "Pickup start required.")]
        public DateTime PickupStart { get; set; }

        [Required(ErrorMessage = "Pickup end required.")]
        public DateTime PickupEnd { get; set; }

        public string? ImageUrl { get; set; } = string.Empty;
    }

    public class PackageListItem
    {
        public Guid Uid { get; set; }
        public Guid BusinessId { get; set; }
        public Guid PackageTypeId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public float Price { get; set; }
        public uint Quantity { get; set; }
        public DateTime PickupStart { get; set; }
        public DateTime PickupEnd { get; set; }
        public string? ImageUrl { get; set; }
    }

    public class BusinessView
    {
        public Guid Uid { get; set; }
        public string Name { get; set; } = string.Empty;
    }


    public class UploadResult
    {
        public string Url { get; set; } = string.Empty;
    }

    public class OrderPackageView 
    {
        public Guid OrderId { get; set; }
        public Guid PackageId { get; set; }
        [Range(1, double.MaxValue, ErrorMessage = "Value must be greater than 0")]
        public uint Quantity { get; set; }
    }
}