@page "/login"
<div class="login_form">
@inject HttpClient http
@inject NavigationManager navigationManager
@rendermode InteractiveServer
@using System.Net;
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity

    <h1>Package Types</h1>

<form method="post" action="/login">
    <input type="hidden" name="returnUrl" value="@ReturnUrl" />
    <div class="form-group row mb-3 justify-content-center">
        <label class="col-md-3 col-form-label">Email <span class="text-danger">*</span></label>
        <div class="col-md-9">
            <input class="form-control" name="email" />
        </div>
    </div>
    <div class="form-group row mb-3">
        <label class="col-md-3 col-form-label">Password <span class="text-danger">*</span></label>
        <div class="col-md-9">
            <input class="form-control" type="password" name="password" />
        </div>
    </div>
    <div class="d-flex justify-content-center gap-2">
        <Button Color="ButtonColor.Primary" @onclick="OpenRegisterModal" >Register</Button>
        <button type="submit" class="btn btn-success">Login</button>
    </div>
</form>

<Modal @ref="modal" Title="Register" IsVerticallyCentered="true">
    <BodyTemplate>
        <EditForm EditContext="@registerEditContext" OnValidSubmit="HandleOnValidRegister">
            <DataAnnotationsValidator />

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Role <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <select class="form-select" @bind="user!.RoleName">
                        <option value="">Select a type</option>
                        @if (roles is not null)
                        {
                            @foreach (var t in roles.Where(role => role.Name != "Admin"))
                            {
                                <option value="@t.Name">@t.Name</option>
                            }
                        }
                    </select>
                    <ValidationMessage For="@(() => user.RoleName)" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Name <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <TextInput @bind-Value="user!.Name" Placeholder="Enter name" />
                    <ValidationMessage For="@(() => user.Name)" />
                </div>
            </div>
            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Email <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <TextInput @bind-Value="user.Email" Placeholder="Enter email" />
                    <ValidationMessage For="@(() => user.Email)" />
                </div>
            </div>
            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">Password <span class="text-danger">*</span></label>
                <div class="col-md-9">
                    <PasswordInput @bind-Value="user.Password" Placeholder="Enter password" />
                    <ValidationMessage For="@(() => user.Password)" />
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <Button Type="ButtonType.Button" Color="ButtonColor.Secondary" @onclick="CloseModal">Cancel</Button>
                <Button Type="ButtonType.Submit" Color="ButtonColor.Success">Save</Button>
            </div>
        </EditForm>
    </BodyTemplate>
</Modal>
</div>

@code {

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }
    private Modal modal = default!;
    private EditContext? editContext;
    private EditContext? registerEditContext;

    private List<IdentityRole<Guid>>? roles = [];
    private UserView? user;
    private UserView? loginUser;

    protected override async Task OnInitializedAsync()
    {
        loginUser = new();
        editContext = new(loginUser);
        roles = await http.GetFromJsonAsync<List<IdentityRole<Guid>>>("api/role");
    }

    private async Task OpenRegisterModal() 
    {
        user = new();
        registerEditContext = new(user);
        await modal.ShowAsync();
    }

    private async Task CloseModal()
    {
        await modal.HideAsync();
    }

    private async Task HandleOnValidRegister() 
    {
        var dto = new UserDTO
        {
            Name = user!.Name!,
            RoleName = user!.RoleName!,
            Email = user!.Email!,
            Password = user!.Password!,

        };

        var res = await http.PostAsJsonAsync("api/auth/register", dto);
        await modal.HideAsync();
    }
    private async Task HandleOnValidSubmit()
    {

        var dto = new LoginDTO
        {
            Email = loginUser!.Email!,
            Password = loginUser!.Password!,

        };

        var res = await http.PostAsJsonAsync("api/auth/login", dto);

        if (res.IsSuccessStatusCode )
            navigationManager.NavigateTo("/", forceLoad: true);
        else {
            Console.WriteLine($"Error received {res.StatusCode}");
        }
    }
    private class UserView {
        public string? Name;
        public string? Email;
        public string? Password;
        public string? RoleName;
    }

}
